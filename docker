

家里immortalwrt nvme需要安装的docker
docker run -d \
  --name=cups \
  --net=host \
  --privileged \
  -e CUPSADMIN=admin \
  -e CUPSPASSWORD=123456 \
  -e TZ=Asia/Shanghai \
  -v /etc/cups:/etc/cups \
  -v /var/log/cups:/var/log/cups \
  -v /dev/bus/usb:/dev/bus/usb \
  -v /var/run/dbus:/var/run/dbus \
  --restart=unless-stopped \
  chuckcharlie/cups-avahi-airprint:latest




# 放行CUPS 631端口
uci add firewall rule
uci set firewall.@rule[-1].name='CUPS'
uci set firewall.@rule[-1].src='lan'
uci set firewall.@rule[-1].target='ACCEPT'
uci set firewall.@rule[-1].proto='tcp'
uci set firewall.@rule[-1].dest_port='631'
uci commit firewall

# 放行mDNS 5353端口（AirPrint发现核心）
uci add firewall rule
uci set firewall.@rule[-1].name='mDNS'
uci set firewall.@rule[-1].src='lan'
uci set firewall.@rule[-1].target='ACCEPT'
uci set firewall.@rule[-1].proto='udp'
uci set firewall.@rule[-1].dest_port='5353'
uci commit firewall

# 重启防火墙生效
/etc/init.d/firewall restart
